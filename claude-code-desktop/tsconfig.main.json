{
  // ============================================================
  // tsconfig.main.json — 主进程 TypeScript 编译配置
  // 专门用于编译 Electron 主进程代码
  // ============================================================
  "compilerOptions": {
    "target": "ES2020",                    // 目标 ECMAScript 版本
    "module": "commonjs",                  // 使用 CommonJS 模块系统（Electron 主进程要求）
    "lib": ["ES2020"],                     // 只包含主进程需要的库
    "outDir": "./dist/main",               // 编译输出目录
    "rootDir": "./src",                    // 源代码根目录
    "strict": true,                        // 启用所有严格类型检查
    "esModuleInterop": true,               // 允许 CommonJS 和 ES 模块互操作
    "skipLibCheck": true,                  // 跳过声明文件的类型检查，加速编译
    "resolveJsonModule": true,             // 允许导入 JSON 模块
    "moduleResolution": "node",            // Node.js 风格的模块解析
    "sourceMap": true,                     // 生成 source map 便于调试
    "declaration": true,                   // 生成类型声明文件
    "noImplicitAny": true,                 // 不允许隐式的 any 类型
    "baseUrl": ".",                        // 基准目录
    "paths": {                             // 路径别名映射
      "*": ["node_modules/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",                    // 只编译主进程源码
    "src/preload/**/*.ts"                  // 预加载脚本也需要编译
  ],
  "exclude": [
    "node_modules",                        // 排除 node_modules
    "dist",                                // 排除输出目录
    "src/renderer"                         // 排除渲染进程代码
  ]
}
